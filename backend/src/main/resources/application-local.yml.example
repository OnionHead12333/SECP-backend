# 本地密钥（仅自己机器）
#
# 使用步骤：
# 1. 复制本文件为同目录下的 application-local.yml
# 2. 填入百度云 OCR 的 API Key / Secret Key
# 3. IDEA 运行配置里 Active profiles 填：dev,local
#
# application-local.yml 已在仓库根目录 .gitignore 中忽略，请勿改名提交。

app:
  baidu:
    ocr:
      api-key: 请替换为你的_API_Key
      secret-key: 请替换为你的_Secret_Key
  preprocess:
    enabled: true
    max-width: 2000
    jpeg-quality: 0.85
    # 可选：保存预处理产物用于调试（例如 /tmp/ocr-preprocessed 或 C:\temp\ocr）
    temp-dir: 
